# LLM providers
GOOGLE_API_KEY=
GROQ_API_KEY=

# Pinecone vector store
PINECONE_API_KEY=
PINECONE_INDEX_NAME=documind

# Redis session store
# Local dev: redis://localhost:6379
# Docker Compose: redis://redis:6379
# DO Managed Redis: rediss://<user>:<pass>@<host>:25061
REDIS_URL=redis://localhost:6379

# Object storage (AWS S3 or DigitalOcean Spaces)
# For DO Spaces set S3_ENDPOINT_URL=https://<region>.digitaloceanspaces.com
# For AWS S3 leave S3_ENDPOINT_URL blank
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=documind-uploads
S3_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com
